# Ensure shell scripts always have LF line endings (required by Linux containers)
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.go text eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.properties text eol=lf
Makefile text eol=lf

# Windows-native files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
mvnw.cmd text eol=crlf
